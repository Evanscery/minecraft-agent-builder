# Python
backend/__pycache__/
backend/app/**/__pycache__/
backend/tests/__pycache__/
backend/.pytest_cache/
backend/app/data/blocks_cache/
*.pyc

# Frontend
frontend/node_modules/
frontend/dist/
package-lock.json

# Env / secrets — never commit
.env
.env.local
.env.*
!.env.example

# Agent / tool session state
.omo/
.claude/
.codegraph/

# Dev logs
*.log

# Temporary CDP / browser test artifacts
.tmp_cdp/

# UI screenshot harness output (regenerated by frontend/harness.cjs)
uishots/

# Stray root-level API response dumps from manual testing
/exp.json
/mats.json
/patch.json
/prev.json
/prev2.json
/ref.json
/undo.json
/val.json
